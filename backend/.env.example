# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# Anthropic Claude API key — used by the extraction service to call Claude with an image
ANTHROPIC_API_KEY=

# MongoDB connection string — e.g. mongodb+srv://user:pass@cluster.mongodb.net/sipar
MONGODB_URI=

# Database path (optional) — used for separating dev/prod databases.
# In production on Render, this is unset and defaults to data/app.db.
# In local/testing mode, set this to direct the backend to a development/test SQLite file.
# DATABASE_PATH=data/app_dev.db

